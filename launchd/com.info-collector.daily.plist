<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.info-collector.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/greapi/project/info-collerctor &amp;&amp; /usr/bin/env python3 daily_workflow.py &gt;&gt; logs/daily_workflow.log 2&gt;&amp;1</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>4</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>WorkingDirectory</key>
  <string>/Users/greapi/project/info-collerctor</string>

  <key>StandardOutPath</key>
  <string>/Users/greapi/project/info-collerctor/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/greapi/project/info-collerctor/logs/launchd.err.log</string>
</dict>
</plist>
