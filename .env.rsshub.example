# Copy this file to .env.rsshub before starting RSSHub.

# Bind RSSHub to localhost by default. Use 0.0.0.0 only when you have firewall
# or reverse proxy protection in place.
RSSHUB_HOST=127.0.0.1
RSSHUB_PORT=1200

# Image tags can be pinned for reproducible deployments.
RSSHUB_IMAGE=diygod/rsshub:latest
BROWSERLESS_IMAGE=browserless/chrome:latest
REDIS_IMAGE=redis:7-alpine

# Optional RSSHub configuration.
# CACHE_EXPIRE=600
# REQUEST_TIMEOUT=30000
# TITLE_LENGTH_LIMIT=150

# Some RSSHub routes need tokens or cookies. Add route-specific environment
# variables below when required by the RSSHub route documentation.
# GitHub Trending requires this token.
# GITHUB_ACCESS_TOKEN=
# YOUTUBE_KEY=
